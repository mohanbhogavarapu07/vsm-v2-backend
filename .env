APP_NAME="VSM Backend"
APP_VERSION="1.0.0"
DEBUG=false
LOG_LEVEL=INFO

# ── Supabase / Prisma ─────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → Database → Connection String
#
# DATABASE_URL  → "Transaction" mode (pgbouncer pooling, port 6543) - used by the app
# DIRECT_URL    → "Session" mode  (port 5432) - used by `prisma db push` / migrations
#
# With connection pooling (recommended for production):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

DATABASE_URL=postgresql://postgres.bfzitnkxgyzyqdyjkbta:9502812714msn@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.bfzitnkxgyzyqdyjkbta:9502812714msn@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres


# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# ⚠️  All three must use /0  — Upstash free tier has only ONE database (DB 0)
# ⚠️  Use rediss:// (double s) for TLS — Upstash requires it
REDIS_URL=rediss://default:gQAAAAAAAV_VAAIncDFmMjY3YmUyYTQ2MjQ0Mjg0OTI3YzkxYWMyOGQ0YzhjMHAxOTAwNjk@stable-elephant-90069.upstash.io:6379/0
CELERY_BROKER_URL=rediss://default:gQAAAAAAAV_VAAIncDFmMjY3YmUyYTQ2MjQ0Mjg0OTI3YzkxYWMyOGQ0YzhjMHAxOTAwNjk@stable-elephant-90069.upstash.io:6379/0
CELERY_RESULT_BACKEND=rediss://default:gQAAAAAAAV_VAAIncDFmMjY3YmUyYTQ2MjQ0Mjg0OTI3YzkxYWMyOGQ0YzhjMHAxOTAwNjk@stable-elephant-90069.upstash.io:6379/0

# ── Event Aggregation ─────────────────────────────────────────────────────────
AGGREGATION_WINDOW_SECONDS=30
AGGREGATION_MAX_EVENTS=100

# ── AI Agent Layer ────────────────────────────────────────────────────────────
AI_AGENT_URL=http://localhost:8001
AI_AGENT_TIMEOUT=30

# ── Webhook Security ──────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=vsm-github-secret-xK9mP2qL8nR4tJ7w
WEBHOOK_HMAC_ENABLED=true

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_BACKOFF=5

# ── NLP Thresholds ────────────────────────────────────────────────────────────
NLP_AUTO_EXECUTE_THRESHOLD=0.85
NLP_ASK_USER_THRESHOLD=0.60

# ── Unlinked Activity ─────────────────────────────────────────────────────────
UNLINKED_AUTO_LINK_THRESHOLD=0.85
UNLINKED_ASK_USER_THRESHOLD=0.60

# ── Email Settings (Resend.com) ───────────────────────────────────────────────
# Get your API key at https://resend.com/
RESEND_API_KEY=re_5xGhnSgC_67TuzQuk8Cmp7kRs75uesMJY
RESEND_FROM=onboarding@resend.dev

# ── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080
