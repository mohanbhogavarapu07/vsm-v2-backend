# pyenv
#   For a library or binary, you should probably not check in .python-version
.python-version

# pipenv
#   According to pypa/pipenv#125, it is NOT recommended to check in Pipfile.lock with libraries.
#   For apps, you should check in Pipfile.lock.
# Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is NOT recommended to check in poetry.lock with libraries.
#   For apps, you should check in poetry.lock.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is NOT recommended to check in pdm.lock with libraries.
#   pdm.lock
#   pdm.lock.sh
#   .pdm-python
#   .pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
