// VSM Backend – Prisma Schema
// Maps all tables to Supabase PostgreSQL
// Uses prisma-client-py for async Python access

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Supabase pooled connection (pgbouncer)
  directUrl = env("DIRECT_URL") // Supabase direct connection (for migrations)
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum TaskStatusCategory {
  BACKLOG
  TODO
  ACTIVE
  REVIEW
  VALIDATION
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

enum WorkflowReadiness {
  DRAFT
  INCOMPLETE
  ACTIVE
}

enum ScopeType {
  PROJECT
  TEAM
}

enum DirectionType {
  FORWARD
  BACKWARD
  PARALLEL
}

enum TriggerType {
  GITHUB_EVENT
  MANUAL
  TIMER
  CONDITION_MET
}

enum ConditionType {
  PR_CREATED
  PR_MERGED
  CI_PASSED
  CI_FAILED
  COMMENT_ADDED
  QA_APPROVED
  DOCS_UPDATED
  SECURITY_SCAN_PASSED
}

enum ConditionOperator {
  AND
  OR
}

enum EventType {
  GIT_COMMIT
  PR_CREATED
  PR_MERGED
  CI_STATUS
  CHAT_MESSAGE
}

enum EventSource {
  GITHUB
  SLACK
  CI
  SYSTEM
}

enum QueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum WindowStatus {
  OPEN
  CLOSED
}

enum ActivityType {
  COMMIT
  PR
  CI
  COMMENT
}

enum AuthProvider {
  EMAIL
  GOOGLE
}


enum DetectedIntent {
  BLOCKER
  PROGRESS
  COMPLETION
  CONFUSION
}

enum FeedbackResult {
  ACCEPTED
  REJECTED
}

enum CorrectedIntent {
  BLOCKER
  PROGRESS
  NONE
}

enum MappingMethod {
  MANUAL
  AI_AUTO
  BRANCH_PATTERN
}

enum DecisionSource {
  RULE_ENGINE
  AI_MODEL
}

enum AgentDecisionStatus {
  APPLIED
  BLOCKED
  NO_TRANSITION
  FUZZY_LINK
  PENDING_CONFIRMATION
  RESOLVED_MANUALLY
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE ENTITIES (RBAC)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id             BigInt       @id @default(autoincrement())
  email          String       @unique @db.VarChar(255)
  name           String       @db.VarChar(255)
  authProvider   AuthProvider @default(EMAIL)
  jobTitle       String?      @db.VarChar(100)
  department     String?      @db.VarChar(100)
  phone          String?      @db.VarChar(50)
  bio            String?      @db.Text
  bannerGradient String?      @db.VarChar(255)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  memberships        TeamMember[]
  projectMembers     ProjectMember[]
  invitationsSent    TeamInvitation[]   @relation("InvitationsSent")
  chatMessages       ChatMessage[]
  nlpFeedbacks       NLPFeedback[]

  @@map("users")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  code        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@map("permissions")
}

model Project {
  id                BigInt            @id @default(autoincrement())
  name              String            @db.VarChar(255)
  setupComplete     Boolean           @default(false)
  workflowReadiness WorkflowReadiness @default(DRAFT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  teams               Team[]
  roles               ProjectRole[]
  workflowStages      WorkflowStage[]
  projectMembers      ProjectMember[]

  @@map("projects")
}

model Team {
  id        BigInt   @id @default(autoincrement())
  projectId BigInt
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members            TeamMember[]
  invitations        TeamInvitation[]
  sprints            Sprint[]
  tasks              Task[]
  githubRepositories GitHubRepository[]
  chatMessages       ChatMessage[]
  workflowStages     WorkflowStage[]
  systemNotifications SystemNotification[]
  systemBlockers      SystemBlocker[]

  @@index([projectId])
  @@map("teams")
}

model ProjectRole {
  id        BigInt   @id @default(autoincrement())
  projectId BigInt
  name      String   @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members         TeamMember[]
  rolePermissions RolePermission[]
  invitations     TeamInvitation[]
  projectMembers  ProjectMember[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("project_roles")
}

model RolePermission {
  id           BigInt   @id @default(autoincrement())
  roleId       BigInt
  permissionId BigInt
  createdAt    DateTime @default(now())

  role       ProjectRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model ProjectMember {
  id        BigInt   @id @default(autoincrement())
  projectId BigInt
  userId    BigInt
  roleId    BigInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    ProjectRole @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model TeamMember {
  id        BigInt   @id @default(autoincrement())
  teamId    BigInt
  userId    BigInt
  roleId    BigInt
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team  Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role  ProjectRole @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tasks Task[]

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
  @@map("team_members")
}

model TeamInvitation {
  id          BigInt    @id @default(autoincrement())
  teamId      BigInt
  email       String    @db.VarChar(255)
  roleId      BigInt
  invitedById BigInt?
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team      Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  role      ProjectRole @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy User?       @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([teamId, email])
  @@index([teamId])
  @@index([roleId])
  @@map("team_invitations")
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOW & TASKS
// ─────────────────────────────────────────────────────────────────────────────

model Sprint {
  id        BigInt       @id @default(autoincrement())
  teamId    BigInt
  name      String       @db.VarChar(255)
  goal      String?
  startDate DateTime?
  endDate   DateTime?
  status    SprintStatus @default(PLANNED)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  team  Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([teamId])
  @@index([status])
  @@map("sprints")
}

model WorkflowStage {
  id                     BigInt             @id @default(autoincrement())
  projectId              BigInt
  name                   String             @db.VarChar(100)
  systemCategory         TaskStatusCategory
  intentTag              String?            @db.VarChar(100)
  positionOrder          Int                @default(0)
  scopeType              ScopeType          @default(PROJECT)
  teamId                 BigInt?
  isBlocking             Boolean            @default(false)
  requiresApprovalToExit Boolean            @default(false)
  slaDurationMinutes     Int?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  team            Team?                @relation(fields: [teamId], references: [id], onDelete: SetNull)
  tasks           Task[]
  decisionsFrom   AgentDecision[]      @relation("DecisionFromStage")
  decisionsTo     AgentDecision[]      @relation("DecisionToStage")

  @@unique([projectId, positionOrder])
  @@index([projectId])
  @@map("workflow_stages")
}

model Task {
  id              BigInt       @id @default(autoincrement())
  teamId          BigInt
  sprintId        BigInt?
  title           String       @db.VarChar(500)
  description     String?
  priority        TaskPriority @default(MEDIUM)
  order           Float        @default(1000)
  currentStageId  BigInt?
  assigneeId      BigInt?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  team          Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sprint        Sprint?         @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  currentStage  WorkflowStage?  @relation(fields: [currentStageId], references: [id])
  assignee      TeamMember?     @relation(fields: [assigneeId], references: [id])
  activities    TaskActivity[]
  decisions     AgentDecision[]
  nlpInsights   NLPInsight[]
  systemNotifications SystemNotification[]
  systemBlockers      SystemBlocker[]

  @@index([teamId])
  @@index([assigneeId])
  @@map("tasks")
}

// ─────────────────────────────────────────────────────────────────────────────
// EVENT SYSTEM
// ─────────────────────────────────────────────────────────────────────────────

model EventLog {
  id                 BigInt      @id @default(autoincrement())
  eventType          EventType
  source             EventSource
  referenceId        String?     @db.VarChar(255)
  payload            Json
  installationId     BigInt?
  repositoryId       BigInt?
  eventTimestamp     DateTime
  ingestionTimestamp DateTime    @default(now())
  processed          Boolean     @default(false)
  correlationId      String?     @db.VarChar(255)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  queueEntry EventProcessingQueue?

  @@index([eventType, eventTimestamp])
  @@index([processed])
  @@index([correlationId])
  @@index([installationId])
  @@index([repositoryId])
  @@map("event_log")
}

model EventProcessingQueue {
  id           BigInt      @id @default(autoincrement())
  eventId      BigInt      @unique
  status       QueueStatus @default(PENDING)
  retryCount   Int         @default(0)
  scheduledAt  DateTime?
  errorMessage String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  event EventLog @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("event_processing_queue")
}

model EventAggregationWindow {
  id               BigInt       @id @default(autoincrement())
  correlationId    String       @db.VarChar(255)
  startTime        DateTime
  endTime          DateTime?
  aggregatedEvents Json
  status           WindowStatus @default(OPEN)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([correlationId])
  @@index([status])
  @@map("event_aggregation_window")
}

// ─────────────────────────────────────────────────────────────────────────────
// DATA MODELS
// ─────────────────────────────────────────────────────────────────────────────

model TaskActivity {
  id           BigInt       @id @default(autoincrement())
  taskId       BigInt?
  activityType ActivityType
  referenceId  String?      @db.VarChar(255)
  metadata     Json         @default("{}")
  eventLogId   BigInt?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([activityType])
  @@map("task_activity")
}

// ─────────────────────────────────────────────────────────────────────────────
// GITHUB APP INTEGRATION
// ─────────────────────────────────────────────────────────────────────────────

model GitHubInstallation {
  id          BigInt   @id // GitHub's installation_id
  accountName String   @db.VarChar(255)
  appId       String   @db.VarChar(100)
  targetId    BigInt // GitHub Account ID
  targetType  String   @db.VarChar(50) // User or Organization
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  repositories GitHubRepository[]

  @@map("github_installations")
}

model GitHubRepository {
  id             BigInt  @id // GitHub's repository_id
  name           String  @db.VarChar(255)
  fullName       String  @db.VarChar(500)
  installationId BigInt
  teamId         BigInt? // Nullable until linked to a specific team

  installation GitHubInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  team         Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([installationId])
  @@index([teamId])
  @@map("github_repositories")
}

// ─────────────────────────────────────────────────────────────────────────────
// NLP SYSTEM 
// ─────────────────────────────────────────────────────────────────────────────

model ChatMessage {
  id                BigInt   @id @default(autoincrement())
  userId            BigInt
  teamId            BigInt
  message           String
  timestamp         DateTime
  platformMessageId String?  @unique @db.VarChar(255)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id])
  team     Team         @relation(fields: [teamId], references: [id])
  insights NLPInsight[]

  @@index([userId])
  @@index([teamId])
  @@map("chat_messages")
}

model NLPInsight {
  id                   BigInt         @id @default(autoincrement())
  messageId            BigInt
  taskId               BigInt?
  detectedIntent       DetectedIntent
  confidenceScore      Float
  requiresConfirmation Boolean        @default(false)
  contextSnapshot      Json           @default("{}")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  message  ChatMessage   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  task     Task?         @relation(fields: [taskId], references: [id], onDelete: SetNull)
  feedback NLPFeedback[]

  @@index([confidenceScore])
  @@index([taskId])
  @@map("nlp_insights")
}

model NLPFeedback {
  id              BigInt           @id @default(autoincrement())
  insightId       BigInt
  userId          BigInt
  feedback        FeedbackResult
  correctedIntent CorrectedIntent?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  insight NLPInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id])

  @@index([insightId])
  @@map("nlp_feedback")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI DECISION TRACEABILITY 
// ─────────────────────────────────────────────────────────────────────────────

model AgentDecision {
  id               BigInt              @id @default(autoincrement())
  taskId           BigInt
  fromStageId      BigInt?
  toStageId        BigInt?
  confidenceScore  Float
  reasoning        String              @db.Text
  correlationId    String?             @db.VarChar(255)
  status           AgentDecisionStatus @default(PENDING_CONFIRMATION)
  triggeredByEvent String?             @db.VarChar(100)
  inputSignals     Json                @default("{}")
  decisionSource   DecisionSource      @default(AI_MODEL)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  task       Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStage  WorkflowStage?      @relation("DecisionFromStage", fields: [fromStageId], references: [id])
  toStage    WorkflowStage?      @relation("DecisionToStage", fields: [toStageId], references: [id])

  @@index([taskId])
  @@index([correlationId])
  @@map("agent_decisions")
}


model SystemNotification {
  id         BigInt   @id @default(autoincrement())
  teamId     BigInt?
  taskId     BigInt?
  title      String   @db.VarChar(255)
  message    String   @db.Text
  type       String   @db.VarChar(50)
  sourceType String   @default("INFO") @db.VarChar(50)
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([taskId])
  @@index([isRead])
  @@map("system_notifications")
}

model SystemBlocker {
  id          BigInt   @id @default(autoincrement())
  teamId      BigInt
  taskId      BigInt?
  title       String   @db.VarChar(255)
  description String   @db.Text
  type        String   @db.VarChar(50)
  isResolved  Boolean  @default(false)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([isResolved])
  @@map("system_blockers")
}
